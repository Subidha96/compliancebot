# ComplianceBot+ Environment Variables

# Application
DEBUG=false
APP_NAME=ComplianceBot+
APP_VERSION=0.1.0

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000

# LLM Configuration
MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.3
FALLBACK_MODEL=Qwen/Qwen2-0.5B-Instruct
USE_GPU=true
MAX_NEW_TOKENS=1024
TEMPERATURE=0.7

# Ollama backend (use local Ollama server instead of transformers)
USE_OLLAMA=true
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen3.5:2b

# RAG Configuration — multilingual models for EN+NE support
EMBEDDING_MODEL=intfloat/multilingual-e5-base
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=nepal_grc_corpus

# Translation
TRANSLATION_MODEL=facebook/nllb-200-distilled-600M
TRANSLATE_OUTPUT=true

# Explainability
SHAP_ENABLED=true

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
SESSION_STORE_TYPE=memory

# Rate Limiting
CHAT_RATE_LIMIT=30
GAP_ASSESSMENT_RATE_LIMIT=10

# Bias Audit
BIAS_THRESHOLD=0.3

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8002